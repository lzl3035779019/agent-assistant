APP_NAME=PMAA
APP_ENV=local
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
SEARCH_PROVIDER=tavily_mcp
MAX_REFLECTION_RETRIES=1
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_MAX_RESULTS=5
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_MONITOR_MAX_RESULTS=10
GBRAIN_MCP_ENABLED=false
GBRAIN_MCP_TRANSPORT=stdio
GBRAIN_MCP_COMMAND=wsl.exe
GBRAIN_MCP_ARGS=-d|Ubuntu|--|bash|/home/lzl/.local/bin/gbrain-wiki-mcp
GBRAIN_MCP_URL=
GBRAIN_MCP_SEARCH_TOOL=wiki_search
GBRAIN_MCP_GET_PAGE_TOOL=wiki_get_page
GBRAIN_MCP_MAX_RESULTS=5
GBRAIN_INBOX_DIR=C:\Users\lzl\GbrainInbox
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# QQ Mail IMAP/SMTP. Use QQ Mail authorization code, not account password.
QQ_EMAIL_ADDRESS=
QQ_EMAIL_AUTH_CODE=
QQ_EMAIL_IMAP_HOST=imap.qq.com
QQ_EMAIL_IMAP_PORT=993
QQ_EMAIL_SMTP_HOST=smtp.qq.com
QQ_EMAIL_SMTP_PORT=465

# Daily Brief calendar source. Use disabled or ics for the first release.
CALENDAR_PROVIDER=disabled
CALENDAR_ICS_PATH=
CALENDAR_TIMEZONE=Asia/Shanghai

# Background automation. Disabled by default to avoid unplanned API usage.
AUTOMATION_SCHEDULER_ENABLED=false
AUTOMATION_POLL_SECONDS=60
DAILY_BRIEF_SCHEDULE_ENABLED=false
DAILY_BRIEF_SCHEDULE_TIME=08:00
